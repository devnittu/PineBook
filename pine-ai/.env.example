# Python FastAPI — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/pinebook

# --- FAISS ---
FAISS_INDEX_PATH=data/faiss.index
FAISS_META_PATH=data/faiss_meta.json

# --- Model ---
MODEL_NAME=all-MiniLM-L6-v2
TOP_K=5

# --- Logging ---
LOG_LEVEL=INFO

# --- Server ---
HOST=0.0.0.0
PORT=8000
